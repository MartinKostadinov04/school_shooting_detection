# ─────────────────────────────────────────────────────────
# Python — FastAPI backend + audio pipeline
# Copy to .env and fill in real values (never commit .env)
# ─────────────────────────────────────────────────────────

# Ably (full key: app_id.key_name:key_secret)
ABLY_API_KEY=

# AWS — for S3 audio snippet upload (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=

# JWT signing secret — change before deploying
JWT_SECRET=change-me-in-production

# SQLAlchemy database URL
# SQLite (default, dev): sqlite:///data/tacticaleye.db
# Postgres (prod):       postgresql://user:pass@host/db
DATABASE_URL=sqlite:///data/tacticaleye.db

# Modal cloud GPU (for embedding extraction)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# ─────────────────────────────────────────────────────────
# Frontend — copy the lines below to frontend/.env.local
# ─────────────────────────────────────────────────────────

# Leave blank — the frontend fetches a token from /api/ably-token instead
VITE_ABLY_API_KEY=

# FastAPI backend base URL
VITE_API_BASE_URL=http://localhost:8000
